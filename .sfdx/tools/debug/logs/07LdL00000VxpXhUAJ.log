Execute Anonymous:     FROM Location
Execute Anonymous:     WHERE Name = 'Tech Van A'
Execute Anonymous:     LIMIT 1
Execute Anonymous: ];
Execute Anonymous: 
Execute Anonymous: if (existingLocations.isEmpty()) {
Execute Anonymous:     vanLocation = new Schema.Location(
Execute Anonymous:         Name = 'Tech Van A',
Execute Anonymous:         IsInventoryLocation = true
Execute Anonymous:     );
Execute Anonymous:     insert vanLocation;
Execute Anonymous: } else {
Execute Anonymous:     vanLocation = existingLocations[0];
Execute Anonymous:     if (vanLocation.IsInventoryLocation == false) {
Execute Anonymous:         vanLocation.IsInventoryLocation = true;
Execute Anonymous:         update vanLocation;
Execute Anonymous:     }
Execute Anonymous: }
Execute Anonymous: 
Execute Anonymous: vanLocation = [
Execute Anonymous:     SELECT Id, Name, IsInventoryLocation
Execute Anonymous:     FROM Location
Execute Anonymous:     WHERE Id = :vanLocation.Id
Execute Anonymous:     LIMIT 1
Execute Anonymous: ];
Execute Anonymous: 
