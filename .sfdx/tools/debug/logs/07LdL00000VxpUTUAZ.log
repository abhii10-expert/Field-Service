Execute Anonymous: // 1. Force YOUR location to 0,0
Execute Anonymous: ServiceResource mySr = [SELECT Id FROM ServiceResource WHERE RelatedRecordId = :UserInfo.getUserId() LIMIT 1];
Execute Anonymous: mySr.LastKnownLatitude = 0.0;
Execute Anonymous: mySr.LastKnownLongitude = 0.0;
Execute Anonymous: update mySr;
Execute Anonymous: 
Execute Anonymous: // 2. Force SARAH'S location to 0.01, 0.01 (Very close)
Execute Anonymous: ServiceResource sarah = [SELECT Id, LocationId FROM ServiceResource WHERE Name = 'Tech Sarah' LIMIT 1];
Execute Anonymous: sarah.LastKnownLatitude = 0.01;
Execute Anonymous: sarah.LastKnownLongitude = 0.01;
Execute Anonymous: update sarah;
Execute Anonymous: 
Execute Anonymous: // 3. Ensure Sarah has stock
Execute Anonymous: Id modemId = [SELECT Id FROM Product2 WHERE Name = 'Modem' LIMIT 1].Id;
Execute Anonymous: ProductItem pi = [SELECT Id FROM ProductItem WHERE LocationId = :sarah.LocationId AND Product2Id = :modemId LIMIT 1];
Execute Anonymous: pi.QuantityOnHand = 15;
Execute Anonymous: update pi;
Execute Anonymous: 
Execute Anonymous: System.debug('SYNC COMPLETE: You and Sarah are now in the same zone. Try the search!');
